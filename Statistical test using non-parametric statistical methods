    {
      "cell_type": "markdown",
      "source": [
        "#Uji Wilcoxon Sampel Tunggal"
      ],
      "metadata": {
        "id": "q_g_uFb4pJDF"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "skor <- c(33, 19, 40, 35, 51, 41, 27, 23, 39, 21,\n",
        "          41, 31, 46, 51, 34, 37, 36, 55, 52, 32)\n",
        "median_h0 <- 45.32"
      ],
      "metadata": {
        "id": "0ZjFS0SZpN6j"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "hasil_uji <- wilcox.test(skor, mu = median_h0, alternative = \"less\", exact = FALSE)\n",
        "print(hasil_uji)"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "Q8jFjl1Kp0HC",
        "outputId": "75f99f55-f471-43d7-e273-e731720446b1"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "\n",
            "\tWilcoxon signed rank test with continuity correction\n",
            "\n",
            "data:  skor\n",
            "V = 31, p-value = 0.003031\n",
            "alternative hypothesis: true location is less than 45.32\n",
            "\n"
          ]
        }
      ]
    },
